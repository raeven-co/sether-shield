{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.3.0",
  "description": "__MSG_extDescription__",
  "default_locale": "en",
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; connect-src 'none';"
  },
  "permissions": ["storage", "activeTab", "scripting", "alarms"],
  "host_permissions": ["https://*/*", "http://*/*"],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Sether Shield",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "dist/background.js"
  },
  "commands": {
    "trigger-scan": {
      "suggested_key": {
        "default": "Alt+Shift+S",
        "mac": "Alt+Shift+S"
      },
      "description": "__MSG_commandTriggerScan__"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://*/*", "http://*/*"],
      "exclude_matches": [
        "https://chrome.google.com/webstore/*"
      ],
      "js": ["dist/content.js"],
      "run_at": "document_idle",
      "all_frames": false
    }
  ]
}
